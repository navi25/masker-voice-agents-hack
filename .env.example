# Cactus Cloud — preferred cloud handoff for the masker pipeline.
# Used by masker.gemma_wrapper.CactusCloudBackend.
CACTUS_CLOUD_KEY=cactus_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional overrides (defaults match cactus/cactus/ffi/cactus_cloud.cpp).
# CACTUS_CLOUD_ENDPOINT=https://104.198.76.3/api/v1/text
# CACTUS_CLOUD_STRICT_SSL=1   # set to require valid TLS cert (default: off, self-signed)

# Direct Gemini key — only needed if you want to bypass Cactus Cloud and
# hit Google's API yourself via google-genai (GeminiCloudBackend).
# GEMINI_API_KEY=
