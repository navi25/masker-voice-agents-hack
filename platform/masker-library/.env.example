# ── Server ──────────────────────────────────────────────────────────────────
MASKER_DEMO_HOST=127.0.0.1
MASKER_DEMO_PORT=8008

# ── Compliance policy ────────────────────────────────────────────────────────
# Options: hipaa_safe_mode | gdpr_safe_mode
MASKER_DEMO_POLICY_MODE=hipaa_safe_mode

# ── STT model ────────────────────────────────────────────────────────────────
# Whisper model size.  Options: tiny.en | base.en | small.en
MASKER_DEMO_STT_MODEL=small.en
MASKER_DEMO_LANGUAGE=en
MASKER_DEMO_SAMPLE_RATE=16000

# ── Partial-result tuning ────────────────────────────────────────────────────
# How often (ms) to flush a partial transcript to the redactor
MASKER_DEMO_PARTIAL_INTERVAL_MS=900

# ── Logging ──────────────────────────────────────────────────────────────────
MASKER_DEMO_LOG_DIR=.masker_safe_logs

# ── Audio device ─────────────────────────────────────────────────────────────
# Leave empty to use the system default microphone
MASKER_DEMO_DEFAULT_DEVICE=
